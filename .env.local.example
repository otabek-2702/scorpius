# Scorpius — environment template. Copy to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real secrets.

# --- Firebase Web config (NOT secret) ---
# Firebase console > Project settings > Your apps > Web app > firebaseConfig
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=scorpius-edu.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=scorpius-edu
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=548461506504
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (SECRET — from the service-account .json) ---
FIREBASE_PROJECT_ID=scorpius-edu
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Gemini (SECRET — aistudio.google.com) ---
GEMINI_API_KEY=

# --- emaktab consented demo account (SECRET) ---
EMAKTAB_USERNAME=
EMAKTAB_PASSWORD=

# --- ElevenLabs (SECRET — elevenlabs.io/app/settings/api-keys) ---
ELEVENLABS_API_KEY=

# Voice IDs — Turkish voices Boss-tested for Uzbek output (Latin-script + phoneme normalizer in lib/ai/voice.ts)
